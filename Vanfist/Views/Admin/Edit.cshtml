
@model Vanfist.Entities.Model
@{
    ViewData["Title"] = "Sửa sản phẩm";
    var categories = ViewBag.Categories as List<Vanfist.Entities.Category>;
}

<h2>Sửa sản phẩm</h2>

<form asp-action="Edit" enctype="multipart/form-data" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Chiều dài</label>
        <input asp-for="Length" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Length" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Chiều rộng</label>
        <input asp-for="Width" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Width" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Chiều cao</label>
        <input asp-for="Height" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Height" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Chiều dài cơ sở (Wheelbase)</label>
        <input asp-for="Wheelbase" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Wheelbase" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>NEDC (Km/lần sạc, 0 nếu xe xăng)</label>
        <input asp-for="NEDC" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="NEDC" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Công suất tối đa</label>
        <input asp-for="MaximumPower" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="MaximumPower" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Mô-men xoắn tối đa</label>
        <input asp-for="MaximumTorque" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="MaximumTorque" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Kích thước vành (RimSize)</label>
        <input asp-for="RimSize" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="RimSize" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Màu sắc</label>
        <input asp-for="Color" class="form-control" />
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Danh mục</label>
        <select asp-for="CategoryId" class="form-control">
            @foreach (var cat in categories)
            {
                <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">
                    @cat.Name
                </option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- Display current image -->
    <div class="form-group">
        <label>Ảnh hiện tại</label>
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            var img = Model.Attachments.First();
            <div>
                <img src="@(Url.Content($"~/uploads/{img.FileName}"))" alt="Ảnh sản phẩm" style="max-width:250px; max-height:250px;" />
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" name="removeImage" value="true" id="removeImage" />
                    <label class="form-check-label" for="removeImage">Xóa ảnh hiện tại</label>
                </div>
            </div>
        }
        else
        {
            <p>Chưa có ảnh</p>
        }
    </div>

    <!-- upload new image -->
    <div class="form-group">
        <label>Ảnh sản phẩm (thay thế)</label>
        <input type="file" name="imageFile" class="form-control" />
        <small class="form-text text-muted">Nếu upload ảnh mới thì ảnh cũ sẽ được xóa và thay bằng ảnh này.</small>
        @Html.ValidationMessage("ImageFile", new { @class = "text-danger" })
    </div>


    <button type="submit" class="btn btn-primary mt-3">Cập nhật</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

