@model IEnumerable<Vanfist.Entities.Model>
@using Vanfist.Entities

<div class="d-flex justify-content-between align-items-center mb-3">
    <a class="btn btn-success" href="@Url.Action("Create", "Admin")">+ Thêm sản phẩm</a>
</div>

<!-- Filter dropdown -->
<div class="mb-3">
    @{
        var selectedCategories = ViewBag.SelectedCategories as List<int> ?? new List<int>();
    }
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
            Lọc theo loại
        </button>
        <ul class="dropdown-menu p-3" aria-labelledby="filterDropdown" style="min-width: 200px;">
            <form method="get" asp-controller="Admin" asp-action="Products">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categories" value="1" id="cat1" @(selectedCategories.Contains(1) ? "checked" : "") />
                    <label class="form-check-label" for="cat1">VF 3</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categories" value="2" id="cat2" @(selectedCategories.Contains(2) ? "checked" : "") />
                    <label class="form-check-label" for="cat2">VF 5</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categories" value="3" id="cat3" @(selectedCategories.Contains(3) ? "checked" : "") />
                    <label class="form-check-label" for="cat3">VF 6</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categories" value="4" id="cat4" @(selectedCategories.Contains(4) ? "checked" : "") />
                    <label class="form-check-label" for="cat4">VF 7</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="categories" value="5" id="cat5" @(selectedCategories.Contains(5) ? "checked" : "") />
                    <label class="form-check-label" for="cat5">VF 8</label>
                </div>
                <button type="submit" class="btn btn-primary btn-sm mt-2 w-100">Lọc</button>
            </form>
        </ul>
    </div>
</div>

<!-- Table -->
<div class="table-responsive mb-4">
    <table class="table table-bordered table-striped mb-0 align-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Loại</th>
                <th>Tác vụ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int rowCount = 0;
                foreach (var item in Model)
                {
                    <tr style="height:60px;">
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@string.Format("{0:N0} VND", item.Price)</td>
                        <td>@(item.Category != null ? item.Category.Name : item.CategoryId.ToString())</td>
                        <td>
                            <a class="btn btn-sm btn-primary" href="@Url.Action("Edit", "Admin", new { id = item.Id })">Sửa</a>
                            <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", "Admin", new { id = item.Id })">Xóa</a>
                        </td>
                    </tr>
                    rowCount++;
                }

                // Thêm hàng trống cho đủ 10 sản phẩm
                for (int i = rowCount; i < 10; i++)
                {
                    <tr style="height:60px;">
                        <td colspan="5"></td>
                    </tr>
                }
            }
            else
            {
                <tr style="height:60px;">
                    <td colspan="5" class="text-center text-muted">Không có sản phẩm nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-3">
        <nav aria-label="Page navigation">
            <ul class="pagination">
                @{
                    int currentPage = ViewBag.CurrentPage ?? 1;
                    int totalPages = ViewBag.TotalPages ?? 1;
                    int maxVisiblePages = 5;

                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, startPage + maxVisiblePages - 1);

                    if (endPage - startPage < maxVisiblePages - 1)
                    {
                        startPage = Math.Max(1, endPage - maxVisiblePages + 1);
                    }
                }

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Products", "Admin", new { page = currentPage - 1, categories = ViewBag.SelectedCategories })">&laquo;</a>
                </li>

                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Products", "Admin", new { page = i, categories = ViewBag.SelectedCategories })">@i</a>
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Products", "Admin", new { page = currentPage + 1, categories = ViewBag.SelectedCategories })">&raquo;</a>
                </li>
            </ul>
        </nav>
    </div>
}
