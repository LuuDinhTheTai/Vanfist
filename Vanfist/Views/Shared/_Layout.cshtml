<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vanfist</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vanfist.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">>_ Vanfist</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-center w-100">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Giới thiệu</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="carDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Ô tô
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="carDropdown">
                                @{
                                    var selectedCategories = ViewBag.SelectedCategories as List<int> ?? new List<int>();
                                }
                                <li>
                                    <form method="get" asp-controller="Home" asp-action="Index" class="px-3 py-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="categories" value="1" @(selectedCategories.Contains(1) ? "checked" : "") />
                                            <label class="form-check-label">VF 3</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="categories" value="2" @(selectedCategories.Contains(2) ? "checked" : "") />
                                            <label class="form-check-label">VF 5</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="categories" value="3" @(selectedCategories.Contains(3) ? "checked" : "") />
                                            <label class="form-check-label">VF 6</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="categories" value="4" @(selectedCategories.Contains(4) ? "checked" : "") />
                                            <label class="form-check-label">VF 7</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="categories" value="5" @(selectedCategories.Contains(5) ? "checked" : "") />
                                            <label class="form-check-label">VF 8</label>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-sm mt-2 w-100">Lọc</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Dịch vụ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Chính sách</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Account" asp-action="Index">
                                <img src="~/image/user.png" alt="Profile" class="navbar-toggler-icon">
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Home" asp-action="Index">
                                <button class="btn btn-outline-primary">
                                    Đăng kí lái thử
                                </button>
                            </form>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                <img src="~/image/earth-globe.png" alt="Language" class="navbar-toggler-icon">
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Vanfist - <a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
